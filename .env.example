OPENAI_API_KEY=

# Anthropic — required for the Guía Médica agent (anthropic/claude-sonnet-4-6)
ANTHROPIC_API_KEY=

# Guía Médica agent — local JSON data backend (POC)
GUIA_MEDICA_BACKEND=local
GUIA_MEDICA_MODEL=openai/gpt-5-mini
GUIA_MEDICA_FICHERO=src/mastra/workspaces/ai_guia_medica/data/cuadro_medico_sample.json

# Mastra Observability — https://projects.mastra.ai
MASTRA_PLATFORM_ACCESS_TOKEN=
MASTRA_PROJECT_ID=

# SQL Server (docker-compose mssql service — used by src/mastra/index.ts)
# Password must meet SQL Server policy (length + upper, lower, digit, symbol).
MSSQL_SA_PASSWORD=change-me
MSSQL_SERVER=localhost
MSSQL_PORT=1433
# Default master works with a plain `docker compose up`; use a dedicated DB in production.
MSSQL_DATABASE=master
MSSQL_USER=sa

# LibSQL file for domains MSSQL does not provide (scores, schedules, datasets, experiments)
# MASTRA_LIBSQL_URL=file:./mastra-local.db
# MASTRA_DATASETS_DB_URL=file:./mastra-local.db

# Studio traces, logs, and metrics (DuckDB — MSSQL observability is spans-only)
# MASTRA_OBSERVABILITY_DB_PATH=./mastra-observability.duckdb

# DBHub MCP for the Mastra monitoring agent (SQL Server tools: execute_sql, search_objects).
# Default: stdio transport runs `npx @bytebase/dbhub` with a sqlserver:// DSN built from MSSQL_* above.
# Optional: point to DBHub HTTP transport instead (see https://dbhub.ai/installation).
# DBHUB_MCP_URL=http://localhost:8080/mcp
