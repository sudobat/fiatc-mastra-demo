# Clave del API de Anthropic. Obtenerla en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Modelo a usar. Sonnet ofrece buen equilibrio coste/calidad para la POC.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Backend del repositorio: 'local' (fichero JSON) o 'api' (API interna FIATC).
GUIA_MEDICA_BACKEND=local

# Ruta al fichero de datos cuando GUIA_MEDICA_BACKEND=local.
GUIA_MEDICA_FICHERO=../data/cuadro_medico_sample.json

# URL base de la API interna FIATC cuando GUIA_MEDICA_BACKEND=api.
# Sólo se usa cuando se implemente ApiInternaFiatcGuiaMedicaRepository.
API_INTERNA_BASE_URL=https://api.interna.fiatc.local
API_INTERNA_TOKEN=
